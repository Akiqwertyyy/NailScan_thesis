<!-- 
  This is an example of required Info.plist entries for the NailScan app.
  
  Add these entries to: ios/Runner/Info.plist
  Insert them inside the <dict> element, before </dict>
-->

<!-- Camera Usage Description -->
<key>NSCameraUsageDescription</key>
<string>NailScan needs camera access to capture images of your fingernails for health analysis.</string>

<!-- Photo Library Usage Description -->
<key>NSPhotoLibraryUsageDescription</key>
<string>NailScan needs photo library access to select nail images for analysis.</string>

<!-- Microphone Usage (required for camera on some iOS versions) -->
<key>NSMicrophoneUsageDescription</key>
<string>Camera access requires microphone permission on this device.</string>

<!-- Photo Library Add Usage (for saving images) -->
<key>NSPhotoLibraryAddUsageDescription</key>
<string>NailScan would like to save analyzed images to your photo library.</string>

<!-- App Display Name -->
<key>CFBundleDisplayName</key>
<string>NailScan</string>

<!-- App Name -->
<key>CFBundleName</key>
<string>NailScan</string>

<!-- Version -->
<key>CFBundleShortVersionString</key>
<string>1.0.0</string>

<!-- Build Number -->
<key>CFBundleVersion</key>
<string>1</string>

<!-- Supported Interface Orientations (Portrait only) -->
<key>UISupportedInterfaceOrientations</key>
<array>
    <string>UIInterfaceOrientationPortrait</string>
</array>

<!-- iPad Supported Orientations (if supporting iPad) -->
<key>UISupportedInterfaceOrientations~ipad</key>
<array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationPortraitUpsideDown</string>
</array>

<!-- Status Bar Style -->
<key>UIStatusBarStyle</key>
<string>UIStatusBarStyleDarkContent</string>

<!-- Requires Full Screen -->
<key>UIRequiresFullScreen</key>
<true/>

<!-- Launch Screen -->
<key>UILaunchStoryboardName</key>
<string>LaunchScreen</string>

<!-- Main Storyboard -->
<key>UIMainStoryboardFile</key>
<string>Main</string>

